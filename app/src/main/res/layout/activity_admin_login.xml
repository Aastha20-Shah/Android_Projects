<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:isScrollContainer="true"
    android:background="@color/lightCream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:scaleType="fitXY"
            android:src="@drawable/black_cup"
            android:contentDescription="App Logo" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/white_full_corner_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Portal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Username"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etAdminUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/light_border_bg"
                android:padding="10dp"
                android:layout_marginTop="6dp"
                android:inputType="text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textStyle="bold"
                android:textColor="@color/darkBrown"
                android:textSize="14sp"
                android:layout_marginTop="14dp" />

            <EditText
                android:id="@+id/etAdminPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/light_border_bg"
                android:padding="10dp"
                android:layout_marginTop="6dp"
                android:inputType="textPassword" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAdminLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/brown_full_corner_bg" />

        </LinearLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="────────  Back to User Area?  ────────"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="@color/brown"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBackToUserLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="User Login"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/darkBrown"
            android:background="@drawable/light_button_bg" />

    </LinearLayout>
</ScrollView>
