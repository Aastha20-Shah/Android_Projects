<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:isScrollContainer="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="100dp"
        android:background="@drawable/white_full_corner_bg">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update Product"
                android:textColor="@color/darkBrown"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/closeBtn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/close"
                android:padding="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/darkBrown" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Product Title"
            android:background="@drawable/light_border_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/darkBrown"
            android:inputType="textCapWords"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Description"
            android:gravity="top"
            android:background="@drawable/light_border_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/darkBrown"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/etExtra"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Extra (e.g. Macchiato)"
            android:background="@drawable/light_border_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/darkBrown"
            android:textSize="16sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etPriceSmall"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Price (S)"
                android:inputType="numberDecimal"
                android:background="@drawable/light_border_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:textColor="@color/darkBrown"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPriceMedium"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Price (M)"
                android:inputType="numberDecimal"
                android:background="@drawable/light_border_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:textColor="@color/darkBrown"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etPriceLarge"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Price (L)"
                android:inputType="numberDecimal"
                android:background="@drawable/light_border_bg"
                android:padding="12dp"
                android:textColor="@color/darkBrown"
                android:textSize="14sp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etRating"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Rating (e.g. 4.5)"
            android:inputType="numberDecimal"
            android:background="@drawable/light_border_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/darkBrown"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/etPicUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:hint="Picture URL (comma separated)"
            android:background="@drawable/light_border_bg"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/darkBrown"
            android:textSize="14sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="6dp"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/light_border_bg"
            android:layout_marginBottom="12dp"/>

        <CheckBox
            android:id="@+id/cbIsPopular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Is Popular Product?"
            android:textColor="@color/darkBrown"
            android:layout_marginBottom="20dp"
            android:textSize="14sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SAVE PRODUCT"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:background="@drawable/brown_full_corner_bg"
            android:layout_marginBottom="10dp"/>

    </LinearLayout>
</ScrollView>