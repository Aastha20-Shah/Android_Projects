<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightCream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:layout_marginHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/backBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:ignore="MissingConstraints">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/back"
                        app:tint="@color/darkBrown"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back"
                        android:textColor="@color/darkBrown"
                        android:layout_marginStart="8dp"
                        android:textSize="16sp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Profile"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PROFILE IMAGE -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="32dp"
                android:layout_gravity="center"
                android:padding="5dp"
                app:shapeAppearanceOverlay="@style/CircleCornerImageView"
                app:strokeColor="@color/darkBrown"
                app:strokeWidth="2dp"
                app:srcCompat="@drawable/profile"/>

            <!-- PROFILE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                android:background="@drawable/white_full_corner_bg"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- FULL NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="@color/brown"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/profileName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"
                    android:textColor="@color/darkBrown"/>

                <!-- PHONE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textColor="@color/brown"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/profilePhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"
                    android:inputType="phone"
                    android:textColor="@color/darkBrown"/>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="@color/brown"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/profileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/darkBrown"/>

                <!-- ADDRESS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown"
                    android:layout_marginTop="20dp"/>

                <EditText
                    android:id="@+id/profileHouse"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="House / Flat"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>
                <EditText
                    android:id="@+id/profileArea"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Apartment / Road / Area"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <!-- LANDMARK -->
                <EditText
                    android:id="@+id/profileLandmark"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Landmark"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/profileCity"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="City"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/profileState"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="State"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/profilePincode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Pincode"
                    android:inputType="number"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/profileCountry"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Country"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <!-- SAVE BUTTON -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/saveProfileBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Save Changes"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/brown_full_corner_bg"/>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Password"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/darkBrown"
                    android:layout_marginTop="20dp"/>

                <EditText
                    android:id="@+id/oldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Current Password"
                    android:inputType="textPassword"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"/>

                <EditText
                    android:id="@+id/newPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="New Password"
                    android:inputType="textPassword"
                    android:background="@drawable/light_border_bg"
                    android:padding="10dp"
                    android:layout_marginTop="10dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/changePasswordBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Update Password"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/brown_full_corner_bg"/>
            </LinearLayout>

            <!-- LOGOUT -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="32dp"
                android:text="Log Out"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:background="@drawable/brown_full_corner_bg"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>