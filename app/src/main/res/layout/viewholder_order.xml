<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/orderDateTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="19 March 2026, 14:30"
                android:textColor="#8C7E7E"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/orderStatusTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/white_full_corner_bg"
                android:backgroundTint="#FFF3E0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="@color/orange"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/orderItemsTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Order #Oo1Heanzas..."
            android:textColor="@color/darkBrown"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F5F5F5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/pic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="4dp"
                android:background="@drawable/brown_full_corner_bg"
                android:backgroundTint="#FDF5E6"
                android:scaleType="centerInside"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/itemSummaryTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cappuccino + 2 more"
                    android:textColor="@color/darkBrown"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/sizeQtyTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Size: Large | Qty: 3"
                    android:textColor="#8C7E7E"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <RatingBar
            android:id="@+id/orderRatingBar"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:numStars="5"
            android:progressTint="@color/orange"
            android:rating="0"
            android:stepSize="1"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F5F5F5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/paymentMethodTxt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Method: COD"
                android:textColor="#8C7E7E"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: "
                android:textColor="@color/darkBrown" />

            <TextView
                android:id="@+id/orderPriceTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹649"
                android:textColor="@color/darkBrown"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>